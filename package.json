{
	"name": "agentdesk",
	"version": "2.8.1",
	"description": "AI-powered development platform with autonomous agent teams",
	"type": "module",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"dev:fast": "concurrently \"vite --port 5173\" \"bunx electrobun dev\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:web": "vite build --config vite.web.config.ts",
		"deploy:web": "wrangler pages deploy dist-web --project-name agentdeskweb --branch=main --commit-dirty=true",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"test": "bun test",
		"typecheck": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/agentdesk-check/tsc.tsbuildinfo",
		"lint": "eslint src/ --cache --cache-strategy content --cache-location node_modules/.cache/agentdesk-check/eslintcache",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
		"prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^4.0.15",
		"@ai-sdk/deepseek": "^3.0.11",
		"@ai-sdk/google": "^4.0.16",
		"@ai-sdk/groq": "^4.0.11",
		"@ai-sdk/openai": "^4.0.14",
		"@ai-sdk/openai-compatible": "^3.0.10",
		"@ai-sdk/provider": "^4.0.3",
		"@ai-sdk/xai": "^4.0.13",
		"@anthropic-ai/claude-agent-sdk": "^0.3.207",
		"@dnd-kit/core": "^6.3.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.0",
		"@huggingface/transformers": "^4.2.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
