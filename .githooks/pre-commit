#!/bin/sh
# AgentDesk pre-commit:
#   1) project-wiki drift nudge   (NON-BLOCKING — informational)
#   2) project health check       (BLOCKING — delegates to check.bat: typecheck + tests + lint)
#
# Bypass everything:        git commit --no-verify
# Bypass just the check:    SKIP_CHECK=1 git commit ...

# --- 1) Wiki drift nudge (never blocks) ---------------------------------------
# Lists wiki pages whose `sources:` include a file you're committing, so they can
# be kept fresh (see project-wiki/WIKI.md). Detection only — never blocks.
if command -v bun >/dev/null 2>&1 && [ -f scripts/wiki-check.mjs ]; then
  bun scripts/wiki-check.mjs --staged || true
fi

# --- 2) Health check (blocks on failure) --------------------------------------
# Runs the SAME check.bat you run by hand — single source of truth for the
# parallel/cached typecheck + tests + lint and the pwsh/powershell selection.
if [ "$SKIP_CHECK" = "1" ]; then
  echo "check: skipped (SKIP_CHECK=1)"
  exit 0
fi
[ -f check.bat ] || exit 0

./check.bat || {
  echo "Commit blocked: a check failed. See details with one of: bun run typecheck | bun test | bun run lint"
  echo "Bypass with: git commit --no-verify"
  exit 1
}
exit 0
